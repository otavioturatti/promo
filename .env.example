# === Banco de Dados (Supabase PostgreSQL) ===
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# === Mercado Livre - Afiliado ===
# Copie os cookies do navegador logado no ML (F12 > Application > Cookies)
ML_COOKIES=_csrf=xxx; ssid=xxx; ...
ML_CSRF_TOKEN=SEU_CSRF_TOKEN_AQUI
ML_AFFILIATE_TAG=alessandrejr

# === SendFlow - WhatsApp ===
SENDFLOW_TOKEN=send_api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDFLOW_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
SENDFLOW_RELEASE_ID=xxxxxxxxxxxxxxxxxxxx
# Campanha para alertas de erro (admin)
SENDFLOW_ALERT_RELEASE_ID=xxxxxxxxxxxxxxxxxxxx

# === Configurações gerais ===
# Timezone (padrão: America/Sao_Paulo)
TZ=America/Sao_Paulo
# Porta do servidor (padrão: 8000)
PORT=8000
